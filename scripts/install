#!/bin/bash
# Open Omniscience - Universal One-Command Installer
# 
# Usage: curl -fsSL https://raw.githubusercontent.com/ideotion/Open-Omniscience/0.01/scripts/install | bash
#        OR: wget -qO- https://raw.githubusercontent.com/ideotion/Open-Omniscience/0.01/scripts/install | bash
#
# This script provides the SIMPLEST way to install and run Open Omniscience with ALL features.
# It automatically detects your system and installs everything needed.
#
# Features:
# - Automatic OS detection (Linux, macOS)
# - Automatic architecture detection (x86_64, arm64)
# - Docker & Docker Compose installation
# - Ollama installation for LLM support
# - One-command deployment
# - Automatic configuration
# - Health verification
# - Clear success/failure messages
#
# Author: Open-Omniscience Team
# License: MIT (Open Source)

# ============================================================================
# INITIALIZATION
# ============================================================================

# Ensure we're running with bash
if [ -z "$BASH_VERSION" ]; then
    echo "Error: This script must be run with bash, not sh."
    echo "Please run: bash <(curl -fsSL https://raw.githubusercontent.com/ideotion/Open-Omniscience/0.01/scripts/install)"
    exit 1
fi

set -euo pipefail

# ============================================================================
# CONFIGURATION - All defaults, user can override with environment variables
# ============================================================================

# Repository settings
REPO_URL="${REPO_URL:-https://github.com/ideotion/Open-Omniscience.git}"
BRANCH="${BRANCH:-0.01}"
INSTALL_DIR="${INSTALL_DIR:-$HOME/open-omniscience}"

# Installation options (can be set via environment or will be asked)
INSTALL_LLM="${INSTALL_LLM:-true}"  # Default to true for full installation
INSTALL_MONITORING="${INSTALL_MONITORING:-false}"  # Optional monitoring stack
SKIP_CONFIRMATION="${SKIP_CONFIRMATION:-false}"  # For non-interactive installs

# Log file
LOG_FILE="/tmp/open-omniscience-install-$(date +%Y%m%d-%H%M%S).log"

# ============================================================================
# COLORS AND FORMATTING
# ============================================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# Check if colors are supported
if [ ! -t 1 ]; then
    RED=''
    GREEN=''
    YELLOW=''
    BLUE=''
    MAGENTA=''
    CYAN=''
    WHITE=''
    BOLD=''
    NC=''
fi

# ============================================================================
# LOGGING FUNCTIONS
# ============================================================================

log() {
    echo -e "${BLUE}➤${NC} $1" | tee -a "$LOG_FILE"
}

success() {
    echo -e "${GREEN}✓${NC} $1" | tee -a "$LOG_FILE"
}

warning() {
    echo -e "${YELLOW}⚠${NC} $1" | tee -a "$LOG_FILE"
}

error() {
    echo -e "${RED}✗${NC} $1" | tee -a "$LOG_FILE"
}

header() {
    echo ""
    echo -e "${BOLD}${CYAN}========================================${NC}"
    echo -e "${BOLD}${CYAN}$1${NC}"
    echo -e "${BOLD}${CYAN}========================================${NC}"
    echo ""
}

section() {
    echo ""
    echo -e "${BOLD}${MAGENTA}$1${NC}"
    echo ""
}

# ============================================================================
# DETECTION FUNCTIONS
# ============================================================================

detect_os() {
    # Detect OS
    if [[ "$OSTYPE" == "linux-gnu"* ]]; then
        OS="linux"
    elif [[ "$OSTYPE" == "darwin"* ]]; then
        OS="macos"
    elif [[ "$OSTYPE" == "cygwin" ]]; then
        OS="windows"
    elif [[ "$OSTYPE" == "msys" ]]; then
        OS="windows"
    else
        OS="unknown"
    fi
    
    # Detect distribution for Linux
    DISTRO="unknown"
    if [ "$OS" = "linux" ]; then
        if [ -f /etc/os-release ]; then
            . /etc/os-release
            DISTRO="$ID"
            DISTRO_VERSION="$VERSION_ID"
        elif type lsb_release >/dev/null 2>&1; then
            DISTRO=$(lsb_release -si 2>/dev/null || echo "unknown")
            DISTRO_VERSION=$(lsb_release -sr 2>/dev/null || echo "unknown")
        fi
    fi
    
    # Detect architecture
    ARCH=$(uname -m)
    case "$ARCH" in
        x86_64) ARCH="amd64" ;;
        aarch64) ARCH="arm64" ;;
        arm64) ARCH="arm64" ;;
        *) ARCH="unknown" ;;
    esac
    
    echo "$OS"
}

detect_sudo() {
    if [ "$EUID" -eq 0 ]; then
        SUDO=""
    else
        SUDO="sudo"
    fi
}

# ============================================================================
# COMMAND CHECKING
# ============================================================================

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# ============================================================================
# INSTALLATION FUNCTIONS
# ============================================================================

install_docker() {
    if command_exists docker && docker --version | grep -q "Docker version"; then
        log "Docker is already installed: $(docker --version 2>/dev/null)"
        return 0
    fi
    
    section "Installing Docker..."
    
    case "$OS" in
        linux)
            case "$DISTRO" in
                ubuntu|debian|pop|linuxmint)
                    log "Installing Docker for Debian/Ubuntu..."
                    $SUDO apt-get update -y
                    $SUDO apt-get install -y ca-certificates curl gnupg
                    $SUDO install -m 0755 -d /etc/apt/keyrings
                    curl -fsSL https://download.docker.com/linux/$DISTRO/gpg | $SUDO gpg --dearmor -o /etc/apt/keyrings/docker.gpg
                    $SUDO chmod a+r /etc/apt/keyrings/docker.gpg
                    echo "deb [arch=$ARCH signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/$DISTRO $DISTRO_VERSION docker ce docker ce-cli containerd.io docker-buildx-plugin docker-compose-plugin" | $SUDO tee /etc/apt/sources.list.d/docker.list > /dev/null
                    $SUDO apt-get update -y
                    $SUDO apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
                    ;;
                centos|rhel|fedora|almalinux|rocky)
                    log "Installing Docker for RHEL-based systems..."
                    $SUDO yum install -y yum-utils
                    $SUDO yum-config-manager --add-repo https://download.docker.com/linux/centos/docker-ce.repo
                    $SUDO yum install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
                    ;;
                arch|manjaro|endeavouros)
                    log "Installing Docker for Arch-based systems..."
                    $SUDO pacman -Syu --noconfirm docker docker-compose
                    ;;
                opensuse|suse)
                    log "Installing Docker for openSUSE..."
                    $SUDO zypper install -y docker docker-compose
                    ;;
                alpine)
                    log "Installing Docker for Alpine Linux..."
                    $SUDO apk add --no-cache docker docker-compose
                    ;;
                *)
                    error "Unsupported Linux distribution: $DISTRO"
                    error "Please install Docker manually from https://docs.docker.com/engine/install/"
                    exit 1
                    ;;
            esac
            ;;
        macos)
            log "Installing Docker for macOS..."
            if ! command_exists brew; then
                error "Homebrew is required for macOS installation."
                error "Please install Homebrew first: /bin/bash -c \"$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\""
                exit 1
            fi
            brew install --cask docker
            ;;
        *)
            error "Unsupported operating system: $OS"
            error "Please install Docker manually from https://docs.docker.com/engine/install/"
            exit 1
            ;;
    esac
    
    # Verify Docker installation
    if ! command_exists docker; then
        error "Docker installation failed. Please install manually."
        exit 1
    fi
    
    success "Docker installed successfully: $(docker --version 2>/dev/null)"
}

install_docker_compose() {
    # Docker Compose is now included with Docker Desktop and some Docker Engine installations
    if docker compose version >/dev/null 2>&1; then
        log "Docker Compose is already installed: $(docker compose version 2>/dev/null)"
        return 0
    fi
    
    # Check for old docker-compose
    if command_exists docker-compose; then
        log "Found docker-compose (standalone): $(docker-compose --version 2>/dev/null)"
        return 0
    fi
    
    section "Installing Docker Compose..."
    
    # Install Docker Compose standalone
    case "$OS" in
        linux|macos)
            log "Installing Docker Compose standalone..."
            $SUDO curl -SL https://github.com/docker/compose/releases/latest/download/docker-compose-linux-$ARCH -o /usr/local/bin/docker-compose
            $SUDO chmod +x /usr/local/bin/docker-compose
            ;;
    esac
    
    # Verify installation
    if ! command_exists docker-compose && ! docker compose version >/dev/null 2>&1; then
        error "Docker Compose installation failed."
        exit 1
    fi
    
    success "Docker Compose installed successfully"
}

install_ollama() {
    if [ "$INSTALL_LLM" != "true" ]; then
        log "Skipping Ollama installation (LLM support disabled)"
        return 0
    fi
    
    if command_exists ollama; then
        log "Ollama is already installed: $(ollama --version 2>/dev/null)"
        return 0
    fi
    
    section "Installing Ollama for LLM support..."
    
    case "$OS" in
        linux)
            log "Installing Ollama for Linux..."
            curl -fsSL https://ollama.com/install.sh | sh
            ;;
        macos)
            log "Installing Ollama for macOS..."
            if command_exists brew; then
                brew install ollama
            else
                curl -fsSL https://ollama.com/install.sh | sh
            fi
            ;;
        *)
            error "Ollama installation not supported for $OS"
            warning "You can still run Open Omniscience without LLM features."
            INSTALL_LLM="false"
            return 0
            ;;
    esac
    
    # Verify Ollama installation
    if ! command_exists ollama; then
        warning "Ollama installation may have failed. LLM features will be limited."
        INSTALL_LLM="false"
        return 0
    fi
    
    success "Ollama installed successfully: $(ollama --version 2>/dev/null)"
}

start_docker_service() {
    section "Starting Docker service..."
    
    case "$OS" in
        linux)
            if command_exists systemctl; then
                if ! systemctl is-active --quiet docker 2>/dev/null; then
                    $SUDO systemctl start docker
                    $SUDO systemctl enable docker
                fi
            elif command_exists service; then
                if ! service docker status >/dev/null 2>&1; then
                    $SUDO service docker start
                fi
            fi
            ;;
        macos)
            # Docker Desktop should auto-start
            if ! docker info >/dev/null 2>&1; then
                warning "Docker Desktop is not running. Please start it manually."
                warning "You can download it from: https://www.docker.com/products/docker-desktop/"
                return 1
            fi
            ;;
    esac
    
    # Add user to docker group if needed (Linux only)
    if [ "$OS" = "linux" ] && [ "$EUID" -ne 0 ]; then
        if ! groups | grep -qw docker; then
            log "Adding current user to docker group..."
            $SUDO usermod -aG docker "$USER"
            warning "You may need to log out and back in for Docker to work without sudo."
            warning "Alternatively, run: newgrp docker"
        fi
    fi
    
    # Verify Docker is running
    if ! docker info >/dev/null 2>&1; then
        error "Docker is not running. Please start Docker manually."
        exit 1
    fi
    
    success "Docker is running and ready"
}

# ============================================================================
# CLONE AND SETUP
# ============================================================================

clone_repository() {
    section "Cloning Open Omniscience repository..."
    
    if [ -d "$INSTALL_DIR/.git" ]; then
        warning "Installation directory $INSTALL_DIR already exists."
        if [ "$SKIP_CONFIRMATION" = "true" ]; then
            log "Overwriting existing installation (SKIP_CONFIRMATION=true)..."
            rm -rf "$INSTALL_DIR"
        else
            read -p "Overwrite existing installation? [y/N]: " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                error "Installation cancelled."
                exit 1
            fi
            rm -rf "$INSTALL_DIR"
        fi
    fi
    
    mkdir -p "$INSTALL_DIR"
    
    log "Cloning repository from $REPO_URL (branch: $BRANCH)..."
    if ! git clone --branch "$BRANCH" --depth 1 "$REPO_URL" "$INSTALL_DIR" 2>&1 | tee -a "$LOG_FILE"; then
        error "Failed to clone repository. Check your internet connection."
        exit 1
    fi
    
    cd "$INSTALL_DIR"
    
    success "Repository cloned to $INSTALL_DIR"
}

configure_environment() {
    section "Configuring environment..."
    
    cd "$INSTALL_DIR"
    
    # Copy example environment file if it exists
    if [ -f ".env.example" ] && [ ! -f ".env" ]; then
        cp .env.example .env
        log "Created .env file from template"
    fi
    
    # Enable LLM settings if requested
    if [ "$INSTALL_LLM" = "true" ]; then
        if [ -f ".env" ]; then
            # Enable LLM in environment
            if ! grep -q "AUTO_DOWNLOAD_MODELS" ".env" 2>/dev/null; then
                echo "" >> .env
                echo "# LLM Settings" >> .env
                echo "AUTO_DOWNLOAD_MODELS=true" >> .env
            fi
        fi
    fi
    
    # Create required directories
    mkdir -p data audit logs ssl
    
    success "Environment configured"
}

# ============================================================================
# DEPLOYMENT FUNCTIONS
# ============================================================================

deploy_with_docker() {
    section "Deploying Open Omniscience with Docker..."
    
    cd "$INSTALL_DIR"
    
    # Determine which compose files to use
    local compose_files=("docker-compose.yml")
    local compose_command="docker compose"
    
    if command_exists docker-compose; then
        compose_command="docker-compose"
    fi
    
    # Add LLM compose file if requested
    if [ "$INSTALL_LLM" = "true" ]; then
        if [ -f "docker-compose.llm.yml" ]; then
            compose_files+=("docker-compose.llm.yml")
            log "Including LLM compose file"
        else
            warning "docker-compose.llm.yml not found, LLM features may be limited"
        fi
    fi
    
    # Add production compose file if monitoring is requested
    if [ "$INSTALL_MONITORING" = "true" ]; then
        if [ -f "docker-compose.production.yml" ]; then
            compose_files+=("docker-compose.production.yml")
            log "Including production compose file with monitoring"
        else
            warning "docker-compose.production.yml not found, monitoring features may be limited"
        fi
    fi
    
    # Build images
    log "Building Docker images..."
    if [ ${#compose_files[@]} -gt 1 ]; then
        $compose_command -f "$(IFS=" "; echo "${compose_files[*]}")" build 2>&1 | tee -a "$LOG_FILE"
    else
        $compose_command build 2>&1 | tee -a "$LOG_FILE"
    fi
    
    # Start containers
    log "Starting containers..."
    if [ ${#compose_files[@]} -gt 1 ]; then
        $compose_command -f "$(IFS=" "; echo "${compose_files[*]}")" up -d 2>&1 | tee -a "$LOG_FILE"
    else
        $compose_command up -d 2>&1 | tee -a "$LOG_FILE"
    fi
    
    success "Containers started"
}

verify_deployment() {
    section "Verifying deployment..."
    
    cd "$INSTALL_DIR"
    
    local compose_command="docker compose"
    if command_exists docker-compose; then
        compose_command="docker-compose"
    fi
    
    # Check if containers are running
    log "Checking container status..."
    local max_attempts=30
    local attempt=1
    local containers_healthy=false
    
    while [ $attempt -le $max_attempts ]; do
        if $compose_command ps 2>/dev/null | grep -q "Up"; then
            containers_healthy=true
            break
        fi
        
        if [ $((attempt % 5)) -eq 0 ]; then
            log "Waiting for containers to start... (attempt $attempt/$max_attempts)"
        fi
        
        sleep 2
        attempt=$((attempt + 1))
    done
    
    if [ "$containers_healthy" = false ]; then
        error "Containers failed to start."
        log "Container logs:"
        $compose_command logs 2>&1 | tee -a "$LOG_FILE"
        exit 1
    fi
    
    success "Containers are running"
    
    # Test API endpoint
    log "Testing API endpoint..."
    local api_healthy=false
    attempt=1
    
    while [ $attempt -le $max_attempts ]; do
        if curl -s http://localhost:8000/api/health >/dev/null 2>&1; then
            api_healthy=true
            break
        fi
        sleep 3
        attempt=$((attempt + 1))
    done
    
    if [ "$api_healthy" = false ]; then
        # Try alternative health endpoint
        attempt=1
        while [ $attempt -le 10 ]; do
            if curl -s http://localhost:8000/ >/dev/null 2>&1; then
                api_healthy=true
                break
            fi
            sleep 5
            attempt=$((attempt + 1))
        done
        
        if [ "$api_healthy" = false ]; then
            warning "API endpoint not responding yet. It may still be initializing."
            warning "Check status with: curl http://localhost:8000/"
        else
            success "API endpoint is responding!"
        fi
    else
        success "API endpoint is responding!"
    fi
    
    # Test LLM endpoint if LLM is enabled
    if [ "$INSTALL_LLM" = "true" ]; then
        log "Testing LLM endpoint..."
        local llm_healthy=false
        attempt=1
        
        while [ $attempt -le 10 ]; do
            if curl -s http://localhost:8000/api/llm/health >/dev/null 2>&1; then
                llm_healthy=true
                break
            fi
            sleep 5
            attempt=$((attempt + 1))
        done
        
        if [ "$llm_healthy" = false ]; then
            warning "LLM endpoint not responding yet. Ollama may take a few minutes to start."
            warning "Check LLM status with: curl http://localhost:8000/api/llm/health"
        else
            success "LLM endpoint is responding!"
        fi
    fi
    
    # Test monitoring endpoints if monitoring is enabled
    if [ "$INSTALL_MONITORING" = "true" ]; then
        log "Testing monitoring endpoints..."
        
        # Test Prometheus
        local prom_healthy=false
        attempt=1
        while [ $attempt -le 10 ]; do
            if curl -s http://localhost:9090 >/dev/null 2>&1; then
                prom_healthy=true
                break
            fi
            sleep 5
            attempt=$((attempt + 1))
        done
        
        if [ "$prom_healthy" = true ]; then
            success "Prometheus is responding!"
        else
            warning "Prometheus not responding yet. Check with: curl http://localhost:9090"
        fi
        
        # Test Grafana
        local grafana_healthy=false
        attempt=1
        while [ $attempt -le 10 ]; do
            if curl -s http://localhost:3000 >/dev/null 2>&1; then
                grafana_healthy=true
                break
            fi
            sleep 5
            attempt=$((attempt + 1))
        done
        
        if [ "$grafana_healthy" = true ]; then
            success "Grafana is responding!"
        else
            warning "Grafana not responding yet. Check with: curl http://localhost:3000"
        fi
    fi
}

# ============================================================================
# MAIN INSTALLATION FUNCTION
# ============================================================================

main() {
    # Initialize log file
    echo "Open Omniscience Installation Log" > "$LOG_FILE"
    echo "Started: $(date)" >> "$LOG_FILE"
    echo "" >> "$LOG_FILE"
    
    # Detect OS and sudo
    OS=$(detect_os)
    detect_sudo
    
    # Show header
    header "Open Omniscience - Universal Installer"
    log "Detected: $OS ($ARCH)"
    log "Install directory: $INSTALL_DIR"
    echo ""
    
    # Check if user wants to proceed (unless SKIP_CONFIRMATION is set)
    if [ "$SKIP_CONFIRMATION" != "true" ]; then
        read -p "This will install Open Omniscience with all dependencies. Continue? [Y/n]: " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]] && [ -z "$REPLY" ]; then
            error "Installation cancelled."
            exit 0
        fi
    fi
    
    # Ask about LLM support (unless already set)
    if [ "$INSTALL_LLM" != "true" ] && [ "$INSTALL_LLM" != "false" ] && [ "$SKIP_CONFIRMATION" != "true" ]; then
        read -p "Install with LLM support (Ollama)? [Y/n]: " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]] || [ -z "$REPLY" ]; then
            INSTALL_LLM="true"
        else
            INSTALL_LLM="false"
        fi
    fi
    
    # Ask about monitoring (unless already set)
    if [ "$INSTALL_MONITORING" != "true" ] && [ "$INSTALL_MONITORING" != "false" ] && [ "$SKIP_CONFIRMATION" != "true" ]; then
        read -p "Install with monitoring (Prometheus + Grafana)? [y/N]: " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            INSTALL_MONITORING="true"
        else
            INSTALL_MONITORING="false"
        fi
    fi
    
    log "Installation options:"
    log "  - LLM Support: $INSTALL_LLM"
    log "  - Monitoring: $INSTALL_MONITORING"
    echo ""
    
    # Install prerequisites
    install_docker
    install_docker_compose
    
    # Start Docker service
    start_docker_service
    
    # Install Ollama if requested
    install_ollama
    
    # Clone repository
    clone_repository
    
    # Configure environment
    configure_environment
    
    # Deploy with Docker
    deploy_with_docker
    
    # Verify deployment
    verify_deployment
    
    # Show completion message
    show_completion_message
}

# ============================================================================
# COMPLETION MESSAGE
# ============================================================================

show_completion_message() {
    header "Installation Complete!"
    
    echo ""
    echo "🎉 Open Omniscience has been successfully installed!"
    echo ""
    
    echo "📁 Installation Directory: $INSTALL_DIR"
    echo ""
    
    echo "🌐 Access Points:"
    echo "   • Web Interface:  http://localhost:8000"
    echo "   • API:           http://localhost:8000/api/"
    echo "   • API Docs:      http://localhost:8000/docs"
    
    if [ "$INSTALL_LLM" = "true" ]; then
        echo "   • LLM API:       http://localhost:8000/api/llm/"
    fi
    
    if [ "$INSTALL_MONITORING" = "true" ]; then
        echo "   • Prometheus:    http://localhost:9090"
        echo "   • Grafana:       http://localhost:3000 (admin/admin)"
    fi
    
    echo ""
    echo "💻 Useful Commands:"
    
    local compose_command="docker compose"
    if command_exists docker-compose; then
        compose_command="docker-compose"
    fi
    
    # Build compose file arguments
    local compose_args=""
    local files=("docker-compose.yml")
    
    if [ "$INSTALL_LLM" = "true" ] && [ -f "$INSTALL_DIR/docker-compose.llm.yml" ]; then
        files+=("docker-compose.llm.yml")
    fi
    
    if [ "$INSTALL_MONITORING" = "true" ] && [ -f "$INSTALL_DIR/docker-compose.production.yml" ]; then
        files+=("docker-compose.production.yml")
    fi
    
    if [ ${#files[@]} -gt 1 ]; then
        compose_args="-f $(IFS=" "; echo "${files[*]}")"
    fi
    
    echo "   Start:    cd $INSTALL_DIR && $compose_command $compose_args up -d"
    echo "   Stop:     cd $INSTALL_DIR && $compose_command $compose_args down"
    echo "   Logs:     cd $INSTALL_DIR && $compose_command $compose_args logs -f"
    echo "   Update:   cd $INSTALL_DIR && git pull && $compose_command $compose_args up -d --build"
    echo "   Status:   cd $INSTALL_DIR && $compose_command $compose_args ps"
    
    if [ "$INSTALL_LLM" = "true" ]; then
        echo ""
        echo "🤖 LLM Features:"
        echo "   • Download models:  docker exec -it open-omniscience-llm ollama pull llama3:8b"
        echo "   • List models:      docker exec -it open-omniscience-llm ollama list"
        echo "   • View LLM GUI:     http://localhost:8000/api/llm/"
    fi
    
    echo ""
    echo "📝 Log File: $LOG_FILE"
    echo ""
    
    echo "========================================"
    echo ""
    
    # Show next steps
    if [ "$INSTALL_LLM" = "true" ]; then
        warning "Ollama is starting. It may take a few minutes to download the first model."
        warning "Check status with: curl http://localhost:8000/api/llm/health"
    fi
    
    if [ "$INSTALL_MONITORING" = "true" ]; then
        warning "Monitoring services may take a few minutes to initialize."
        warning "Access Grafana at http://localhost:3000 (username: admin, password: admin)"
    fi
    
    success "Open Omniscience is ready to use!"
}

# ============================================================================
# ERROR HANDLING
# ============================================================================

trap 'error "Installation failed. Check $LOG_FILE for details."' ERR

# ============================================================================
# RUN MAIN
# ============================================================================

main "$@"
