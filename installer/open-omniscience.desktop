[Desktop Entry]
Version=1.0
Type=Application
Name=Open-Omniscience
GenericName=Investigative Journalism Platform
Comment=Ethical Global Intelligence Platform for Investigative Journalism with Local LLM Support
Exec=bash -c "cd ~/open-omniscience && ~/open-omniscience/venv/bin/python -m uvicorn api.main:app --host 0.0.0.0 --port 8000 --reload & sleep 5 && xdg-open http://localhost:8000"
Icon=/opt/open-omniscience/docs/open-omniscience-icon.png
Terminal=true
Categories=Development;Journalism;Research;Utility;News;
StartupWMClass=Open-Omniscience
MimeType=text/html;
Keywords=journalism;research;news;intelligence;analysis;llm;ai;
StartupNotify=true
