# Open Omniscience Environment Variables
# Copy this file to .env and modify the values for your environment

# Application Settings
APP_NAME=Open Omniscience
APP_VERSION=0.2.0
APP_DEBUG=false

# Database Settings
# For SQLite (default):
DATABASE_URL=sqlite:///data/open_omniscience.db

# For PostgreSQL (uncomment and configure for production):
# DATABASE_URL=postgresql://open_omniscience:change_this_password@localhost:5432/open_omniscience

# Scraping Settings
MAX_WORKERS=5
MAX_RETRIES=3
INITIAL_RETRY_DELAY=1
REQUEST_TIMEOUT=10
USER_AGENT=OpenOmniscience/1.0 (+https://github.com/ideotion/Open-Omniscience)

# Rate Limiting
GLOBAL_RATE_LIMIT=100/hour
SEARCH_RATE_LIMIT=100/hour
EXPORT_RATE_LIMIT=50/hour
SOURCES_RATE_LIMIT=100/hour

# Logging Settings
LOG_LEVEL=INFO
LOG_FILE=logs/open_omniscience.log
MAX_LOG_SIZE=10485760
LOG_BACKUP_COUNT=5

# Audit Settings
AUDIT_ENABLED=true
AUDIT_LOG_DIR=audit

# Frontend Settings
ARTICLES_PER_PAGE=20
DEFAULT_LANGUAGE=en
THEME=system

# Export Settings
MAX_EXPORT_SIZE=10000
CSV_ENCODING=utf-8

# Security Settings
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# Server Settings
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
UVICORN_RELOAD=false

# LLM Settings (Local LLM Support)
OLLAMA_HOST=0.0.0.0
OLLAMA_ORIGINS=*
OLLAMA_BASE_URL=http://localhost:11434
AUTO_DOWNLOAD_MODELS=true
DOWNLOAD_DEFAULT_MODELS=true
LLM_TIMEOUT=120
LLM_MAX_TOKENS=4096
