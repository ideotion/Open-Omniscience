# Open Omniscience — example environment configuration.
# Copy to .env and adjust. Every variable here is read by the code; the app runs
# fine with NONE of them set (sensible defaults apply). Local-first and
# loopback-only by default — nothing below should bind to a public interface.
#
# (Findings SEC-01/SEC-02/DOC-01: this file previously advertised public binds,
# a wildcard LLM CORS, an auto-download path, and a JWT/auth system that does not
# exist in the code. Those have been removed; what remains is the real surface.)

# ── Server (loopback only) ───────────────────────────────────────────────────
OO_HOST=127.0.0.1          # bind address; keep on loopback (local-first)
OO_PORT=8000               # listen port
# OO_AUTOSEED=1            # seed the curated source catalog on first run (default on)
# OO_NO_SCHEDULER=1        # disable the background scrape scheduler entirely
# OO_EPHEMERAL=1           # use a throwaway data dir (amnesic / test runs)

# ── Data & database ──────────────────────────────────────────────────────────
# OO_DATA_DIR=/path/to/data        # overrides the data dir (default: repo data/ or XDG)
# DATABASE_URL=sqlite:///data/open_omniscience.db   # default; SQLite is the supported store
# DATABASE_ECHO=false              # log all SQL (debugging)
# DB_POOL_SIZE=5                   # (PostgreSQL only) connection pool size
# DB_MAX_OVERFLOW=10               # (PostgreSQL only) pool overflow

# ── Ethical fetcher (the single, mandatory scrape path) ──────────────────────
# Politeness/safety are enforced in code regardless of these (robots.txt is
# fail-closed and cannot be disabled). These only tune timing/routing.
# OO_FETCH_MIN_INTERVAL=1.0        # minimum seconds between requests to one host
# OO_FETCH_TIMEOUT=30              # per-request timeout (seconds)
# OO_FETCH_MODE=transparent        # transparent | protected (protected routes via proxy)
# OO_HTTP_PROXY=                   # proxy URL used in protected mode

# ── Local LLM (Ollama — external binary, reached over HTTP, loopback only) ───
# No model is ever auto-downloaded; if one is missing the API tells you to run
# `ollama pull <model>`. Keep Ollama bound to loopback.
# OO_OLLAMA_URL=http://127.0.0.1:11434
# OO_LLM_MODEL=llama3.2:3b

# ── Chain of custody (optional, opt-in) ──────────────────────────────────────
# OO_CUSTODY_ON_INGEST=false       # log an append-only custody entry per ingest
# OO_KEY_PASSPHRASE=               # passphrase for the custody signing key (sensitive)

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_FILE=logs/open_omniscience.log

# ── CORS (loopback only; do not widen on a local-first deployment) ───────────
# CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
