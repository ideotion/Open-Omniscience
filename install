#!/bin/bash
#
# Open-Omniscience One-Line Installer for Debian-based Linux
# ==========================================================
#
# This script provides a fully automatic, non-interactive installation of Open-Omniscience
# with all prerequisites, dependencies, and configurations for Debian-based Linux systems.
#
# Usage: curl -fsSL https://raw.githubusercontent.com/ideotion/Open-Omniscience/0.02/install | bash
#
# Author: Open-Omniscience Team
# License: GPLv3
#

set -uo pipefail
# Make the script interactive by default for better user experience
# This allows prompts to work even when piped (curl ... | bash)
INTERACTIVE=true


# =============================================================================
# Configuration
# =============================================================================

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Version
VERSION="0.02"
REPO_URL="https://github.com/ideotion/Open-Omniscience.git"
REPO_BRANCH="0.02"
INSTALL_DIR="${HOME}/open-omniscience"

# =============================================================================
# Open-Omniscience Logo (ASCII Art - Hexagon with Eye)
# =============================================================================
display_logo() {
    cat << 'EOF'

                                 .-=+*#%@@@@@@@@@@%#*+-:                                        
                            .-+#@@@@@@%%@@@@@@@@@%%%@@@@@@#+:                                   
                         -+%@@@#*=:.-*#*#@*-@=+@#*#*-.:-+*%@@@#=:                               
                      -*@@%+-.    +%+. *#.  @: .*#..=%+     :=#@@%+:                            
                   .+@%*-       :%+##+%*    @:   *%=*#+%-       :=#@%=                          
                 :#%+.         -@:   ##+****@#***+#@   .%=          -*%+.                       
               :*+.           .@:   :@.     @:     @-   .@:            -**.                     
             .=-              *#    *#      @:     *#    *#              .==                    
            :-                #%****@%******@#*****%@****%%                 =                   
             .=:              *#    *#      @:     +#    +#               --                    
               -*=.           :@.   -@      @:     %=   .@-            :++.                     
                 -##-          +%.   %*=+**#@#**+=*%    #*          .=%*.                       
                   :*@#=.       =%=+#*%#.   @:  .*@*#*=%+        :+%%=.                         
                      =#@@*=.    .*%- .#*   @:  +%. :%#:     :=#@@*:                            
                        .=#@@@#+-: .+#*=*@=.@--%#=*#+. .:=*%@@%*-                               
                            :+#@@@@@%**%@@@@@@@@@%**#%@@@@%*=.                                  
                                .-+*%@@@@@@@@@@@@@@@%#+=:                                       
                                       .::-----::.                                              

EOF
}

# =============================================================================
# Utility Functions
# =============================================================================

# Print colored messages
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
}

# Check if command exists
command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# Check if running as root
is_root() {
    [ "$(id -u)" -eq 0 ]
}

# Run command with sudo if not root
run_with_sudo() {
    if is_root; then
        "$@"
    else
        sudo "$@"
    fi
}

# Check if running on a supported Linux system (Debian, Ubuntu, Alpine, Qubes OS, etc.)
is_supported() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        # Support Debian, Ubuntu, and Debian-like systems (including Qubes OS)
        if [[ "$ID" == "debian" || "$ID" == "ubuntu" || ("${ID_LIKE:-}" == *"debian"*) ]]; then
            return 0
        fi
        # Support Alpine Linux (used in some Qubes OS VMs)
        if [[ "$ID" == "alpine" ]]; then
            return 0
        fi
        # Support Qubes OS explicitly
        if [[ "$ID" == "qubes" || "${ID_LIKE:-}" == *"qubes"* ]]; then
            return 0
        fi
    fi
    # If we can't determine, assume supported (for maximum compatibility)
    return 0
}

# Check architecture
check_architecture() {
    ARCH=$(uname -m)
    case "$ARCH" in
        x86_64|amd64|aarch64|arm64)
            log_info "Supported architecture: $ARCH"
            return 0
            ;;
        *)
            log_warning "Unsupported architecture: $ARCH. Installation may fail."
            return 1
            ;;
    esac
}

# =============================================================================
# Pre-Installation Checks
# =============================================================================

check_prerequisites() {
    log_info "Checking prerequisites..."
    
    # Check for curl
    if ! command_exists curl; then
        log_error "curl is required but not installed. Please install curl first."
        exit 1
    fi
    
    # Check for bash
    if ! command_exists bash; then
        log_error "bash is required but not installed."
        exit 1
    fi
    
    # Check architecture
    check_architecture
    
    # Check if running on a supported Linux system
    if ! is_supported; then
        log_warning "This installer is designed for Debian-based Linux systems (including Qubes OS)."
        log_warning "Your system may not be fully supported, but continuing anyway..."
    fi
    
    log_success "Prerequisites check passed"
}

# =============================================================================
# OS Setup (Debian-based Linux only)
# =============================================================================

setup_linux() {
    log_info "Detected Debian-based Linux system"
    
    # Check distribution
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        DISTRO="$ID"
        DISTRO_VERSION="$VERSION_ID"
        log_info "Distribution: $DISTRO $DISTRO_VERSION"
    fi
    
    # Install basic packages
    log_info "Installing basic packages..."
    if command_exists apt-get; then
        run_with_sudo apt-get update -qq
        run_with_sudo apt-get install -y -qq git curl wget ca-certificates gnupg lsb-release
    elif command_exists apk; then
        # Alpine Linux
        run_with_sudo apk update -qq
        run_with_sudo apk add --no-cache git curl wget ca-certificates gnupg
    elif command_exists dnf; then
        # Fedora/RHEL
        run_with_sudo dnf install -y -q git curl wget ca-certificates gnupg
    elif command_exists yum; then
        # Older RHEL/CentOS
        run_with_sudo yum install -y -q git curl wget ca-certificates gnupg
    else
        log_error "Unsupported package manager. Please install git and curl manually."
        log_error "Supported package managers: apt-get, apk, dnf, yum"
        exit 1
    fi
    
    log_success "Basic packages installed"
}

# =============================================================================
# Install Ollama (for LLM support)
# =============================================================================

install_ollama() {
    if command_exists ollama && ollama --version >/dev/null 2>&1; then
        log_info "Ollama is already installed: $(ollama --version)"
        return 0
    fi
    
    log_info "Installing Ollama for local LLM support..."
    
    curl -fsSL https://ollama.com/install.sh | sh
    
    # Verify installation
    if ! command_exists ollama || ! ollama --version >/dev/null 2>&1; then
        log_warning "Ollama installation may have failed or is not in PATH"
        return 1
    fi
    
    log_success "Ollama installed: $(ollama --version)"
    return 0
}

# =============================================================================
# Clone Repository
# =============================================================================

clone_repository() {
    if [ -d "$INSTALL_DIR" ]; then
        log_info "Repository already exists at $INSTALL_DIR"
        cd "$INSTALL_DIR"
        git fetch origin
        git checkout "$REPO_BRANCH"
        git pull origin "$REPO_BRANCH"
        return 0
    fi
    
    log_info "Cloning Open-Omniscience repository..."
    git clone --branch "$REPO_BRANCH" --depth 1 "$REPO_URL" "$INSTALL_DIR"
    
    if [ ! -d "$INSTALL_DIR" ]; then
        log_error "Failed to clone repository"
        exit 1
    fi
    
    cd "$INSTALL_DIR"
    log_success "Repository cloned to $INSTALL_DIR"
}

# =============================================================================
# Install Python Dependencies
# =============================================================================

install_python_deps() {
    log_info "Installing Python dependencies..."
    
    # Check for Python 3.8+
    if ! command_exists python3; then
        log_error "Python 3 is required but not installed"
        exit 1
    fi
    
    PYTHON_VERSION=$(python3 -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')")
    log_info "Detected Python: $PYTHON_VERSION"
    
    # Check Python version - support 3.8 through 3.13
    if ! python3 -c "import sys; assert sys.version_info >= (3, 8) and sys.version_info < (3, 14)" 2>/dev/null; then
        log_error "Python 3.8 through 3.13 is required (detected: $PYTHON_VERSION)"
        exit 1
    fi
    
    # Python 3.13 is now the recommended default for new installations
    if [ "$PYTHON_VERSION" = "3.13" ]; then
        log_success "Python 3.13 detected - recommended for new installations"
    elif [ "$PYTHON_VERSION" = "3.12" ]; then
        log_info "Python 3.12 detected - fully supported"
    else
        log_warning "Python $PYTHON_VERSION detected - supported but 3.13 is recommended for new installations"
    fi
    
    # Create virtual environment
    if [ ! -d "venv" ]; then
        log_info "Creating virtual environment..."
        # Check if python3-venv is available
        if ! python3 -m venv --help >/dev/null 2>&1; then
            # On Debian/Ubuntu, python3-venv package might be needed
            log_info "python3-venv not available, installing..."
            if command_exists apt-get; then
                PYTHON_MAJOR=$(python3 -c "import sys; print(sys.version_info.major)")
                PYTHON_MINOR=$(python3 -c "import sys; print(sys.version_info.minor)")
                # Try generic package first
                if run_with_sudo apt-get install -y python3-venv; then
                    log_success "Installed python3-venv"
                # Try version-specific package
                elif run_with_sudo apt-get install -y "python3.${PYTHON_MAJOR}${PYTHON_MINOR}-venv"; then
                    log_success "Installed python3.${PYTHON_MAJOR}${PYTHON_MINOR}-venv"
                else
                    log_error "Failed to install python3-venv automatically."
                    log_error "Please run manually: sudo apt install python3-venv"
                    exit 1
                fi
            elif command_exists apk; then
                # Alpine Linux: python3 and py3-pip include venv
                if run_with_sudo apk add --no-cache python3 py3-pip; then
                    log_success "Installed python3 and py3-pip (includes venv)"
                else
                    log_error "Failed to install python3. Please run manually: sudo apk add python3 py3-pip"
                    exit 1
                fi
            elif command_exists dnf; then
                # Fedora/RHEL
                if run_with_sudo dnf install -y python3-virtualenv; then
                    log_success "Installed python3-virtualenv"
                else
                    log_error "Failed to install python3-virtualenv. Please run manually: sudo dnf install python3-virtualenv"
                    exit 1
                fi
            elif command_exists yum; then
                # Older RHEL/CentOS
                if run_with_sudo yum install -y python3-virtualenv; then
                    log_success "Installed python3-virtualenv"
                else
                    log_error "Failed to install python3-virtualenv. Please run manually: sudo yum install python3-virtualenv"
                    exit 1
                fi
            else
                log_error "python3-venv is required but not installed."
                log_error "Please install it manually for your package manager."
                exit 1
            fi
        fi
        python3 -m venv venv
    fi
    
    # Activate and install dependencies
    cd "$INSTALL_DIR"
    source venv/bin/activate
    
    # Install core dependencies
    log_info "Installing core dependencies..."
    pip install --upgrade pip setuptools wheel
    
    # Install all dependencies from the unified requirements.txt
    if [ -f "requirements.txt" ]; then
        log_info "Installing all dependencies from unified requirements.txt..."
        pip install -r requirements.txt
    else
        log_error "requirements.txt not found! Cannot install dependencies."
        exit 1
    fi
    
    # Explicitly ensure uvicorn is installed (has been an issue before)
    log_info "Ensuring uvicorn is installed..."
    pip install --upgrade uvicorn[standard]>=0.25.0
    
    # If using Python 3.13, install compatible versions
    if [ "$PYTHON_VERSION" = "3.13" ]; then
        log_info "Detected Python 3.13, installing compatible package versions..."
        pip install --upgrade sqlalchemy>=2.0.25 alembic>=1.13.0 cryptography>=42.0.0 pyyaml>=6.0.1
    fi
    
    log_success "All Python dependencies installed"
}

# =============================================================================
# Configure Environment
# =============================================================================

configure_environment() {
    log_info "Configuring environment..."
    
    # Copy example environment file
    if [ -f ".env.example" ] && [ ! -f ".env" ]; then
        cp .env.example .env
        log_info "Created .env from .env.example"
    fi
    
    # Create data directories
    for dir in data audit logs; do
        if [ ! -d "$dir" ]; then
            mkdir -p "$dir"
            log_info "Created directory: $dir"
        fi
    done
    
    # Set default configuration
    if [ ! -f "configs/settings.yaml" ]; then
        mkdir -p configs
        cat > configs/settings.yaml << 'EOF'
# Open-Omniscience Settings
database:
  url: sqlite:///./data/open_omniscience.db

scraping:
  rate_limit_ms: 1000
  user_agent: "OpenOmniscience/1.0 (+https://github.com/ideotion/Open-Omniscience)"
  respect_robots_txt: true

llm:
  enabled: true
  ollama_host: "http://localhost:11434"
  default_model: "gemma4:e2b"
  auto_download: false

server:
  host: "0.0.0.0"
  port: 8000
  debug: false
EOF
        log_info "Created default settings.yaml"
    fi
    
    log_success "Environment configured"
}

# =============================================================================
# Create Desktop Launcher (Linux)
# =============================================================================

create_desktop_launcher() {
    log_info "Creating desktop launcher..."
    
    # Create desktop file
    DESKTOP_FILE="$HOME/.local/share/applications/open-omniscience.desktop"
    
    # Create directory if it doesn't exist
    mkdir -p "$HOME/.local/share/applications"
    
    # Create the desktop file
    cat > "$DESKTOP_FILE" << EOF
[Desktop Entry]
Version=1.0
Type=Application
Name=Open-Omniscience
GenericName=Investigative Journalism Platform
Comment=Ethical Global Intelligence Platform for Investigative Journalism
Exec=bash -c "cd $INSTALL_DIR && $INSTALL_DIR/venv/bin/python -m uvicorn src.api.main:app --host 0.0.0.0 --port 8000 --reload & sleep 5 && xdg-open http://localhost:8000"
Icon=$INSTALL_DIR/docs/open-omniscience-icon.png
Terminal=true
Categories=Development;Journalism;Research;Utility;
StartupWMClass=Open-Omniscience
EOF
    
    # Make it executable
    chmod +x "$DESKTOP_FILE"
    
    # Update database
    if command_exists update-desktop-database; then
        update-desktop-database "$HOME/.local/share/applications" 2>/dev/null || true
    fi
    
    log_success "Desktop launcher created at $DESKTOP_FILE"
    log_info "You can now find 'Open-Omniscience' in your application menu"
}

# =============================================================================
# Create Systemd Service (Optional)
# =============================================================================

create_systemd_service() {
    log_info "Creating systemd service for production deployment..."
    
    SERVICE_FILE="/etc/systemd/system/open-omniscience.service"
    
    # Get the current user for the service
    CURRENT_USER=$(id -un 2>/dev/null || echo "$USER")
    
    # Create the systemd service file with variables expanded
    cat > /tmp/open-omniscience.service << EOF
[Unit]
Description=Open-Omniscience - Global Intelligence Platform
After=network.target
Requires=network.target

[Service]
User=${CURRENT_USER}
WorkingDirectory=${INSTALL_DIR}
Environment="PATH=${INSTALL_DIR}/venv/bin:$PATH"
Environment="PYTHONUNBUFFERED=1"
ExecStart=${INSTALL_DIR}/venv/bin/python -m uvicorn src.api.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
# Prevent systemd from stopping restarts after too many failures
# This is especially important for Qubes OS which may have aggressive defaults
# Allow up to 10 restarts within 10 minutes before giving up
StartLimitIntervalSec=60
StartLimitBurst=10
# Log to syslog for better debugging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=open-omniscience

[Install]
WantedBy=multi-user.target
EOF
    
    # Copy to systemd directory
    run_with_sudo cp /tmp/open-omniscience.service "$SERVICE_FILE"
    run_with_sudo chmod 644 "$SERVICE_FILE"
    
    # Reload systemd
    if command_exists systemctl; then
        run_with_sudo systemctl daemon-reload
        log_success "Systemd service created at $SERVICE_FILE"
        
        # Test if the service can start before enabling
        log_info "Testing service startup..."
        cd "$INSTALL_DIR"
        
        # Try to start the service and check for immediate errors
        "${INSTALL_DIR}/venv/bin/python" -m uvicorn src.api.main:app --host 0.0.0.0 --port 8000 --timeout-keep-alive 5 2>&1 &
        UVICORN_PID=$!
        sleep 3
        
        # Check if it's running
        if kill -0 $UVICORN_PID 2>/dev/null; then
            log_success "Service test startup: PASSED"
            kill $UVICORN_PID 2>/dev/null
            wait $UVICORN_PID 2>/dev/null
            log_info "To enable: sudo systemctl enable open-omniscience"
            log_info "To start: sudo systemctl start open-omniscience"
        else
            log_warning "Service test startup: FAILED - Check the output above for errors"
            log_warning "The service file has been created but not enabled due to startup failure"
            log_warning "Please fix the issues and manually enable with: sudo systemctl enable open-omniscience"
        fi
    else
        log_warning "systemctl not available, service file created but not enabled"
    fi
    
    rm -f /tmp/open-omniscience.service
}

# =============================================================================
# Verification
# =============================================================================

verify_installation() {
    log_info "Verifying installation..."
    
    local all_passed=true
    
    # Check Git
    if ! command_exists git || ! git --version >/dev/null 2>&1; then
        log_error "Git verification failed"
        all_passed=false
    else
        log_success "Git: $(git --version)"
    fi
    
    # Check Python
    if ! command_exists python3 || ! python3 -c "import sys; assert sys.version_info >= (3, 8)" 2>/dev/null; then
        log_error "Python verification failed"
        all_passed=false
    else
        log_success "Python: $(python3 --version)"
    fi
    
    # Check repository
    if [ ! -d ".git" ]; then
        log_error "Repository verification failed"
        all_passed=false
    else
        log_success "Repository: $(git rev-parse --abbrev-ref HEAD)"
    fi
    
    # Check Python dependencies
    if ! python3 -c "import fastapi; import sqlalchemy; import beautifulsoup4" 2>/dev/null; then
        log_error "Python dependencies verification failed"
        all_passed=false
    else
        log_success "Python dependencies: OK"
    fi
    
    # Check Ollama (optional)
    if command_exists ollama && ollama --version >/dev/null 2>&1; then
        log_success "Ollama: $(ollama --version)"
    else
        log_warning "Ollama: Not installed (LLM features will be limited)"
    fi
    
    if [ "$all_passed" = true ]; then
        log_success "All verification checks passed!"
        return 0
    else
        log_error "Some verification checks failed"
        return 1
    fi
}

# =============================================================================
# Main Installation
# =============================================================================

main() {
    echo ""
    display_logo
    echo "  Open-Omniscience v$VERSION Installer"
    echo "  ===================================="
    echo ""
    
    # Check prerequisites
    check_prerequisites
    
    # Setup for Debian-based Linux
    setup_linux
    
    # Ollama installation is optional and skipped by default for faster testing
    # It can be installed later from within the app or manually from https://ollama.com
    if [ "$INTERACTIVE" = true ]; then
        read -p "Do you want to install Ollama for LLM support? (y/N): " -n 1 -r
        echo ""
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            install_ollama || log_warning "Ollama installation skipped or failed"
        else
            log_info "Skipping Ollama installation (recommended for testing). You can install it later from within the app or from https://ollama.com"
        fi
    else
        # Non-interactive mode: skip Ollama by default for faster installation
        log_info "Skipping Ollama installation (can be installed later from within the app)."
    fi
    
    # Clone repository
    clone_repository
    
    # Ensure we're in the install directory
    cd "$INSTALL_DIR"
    
    # Install Python dependencies
    install_python_deps
    
    # Configure environment
    configure_environment
    
    # Create desktop launcher
    create_desktop_launcher
    
    # Create systemd service (optional)
    if [ "$INTERACTIVE" = true ]; then
        read -p "Do you want to create a systemd service for production? (y/N): " -n 1 -r
        echo ""
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            create_systemd_service
        fi
    fi
    
    # Verify installation
    echo ""
    log_info "Running verification..."
    verify_installation
    
    # Final message
    echo ""
    display_logo
    echo "  Installation Complete!"
    echo ""
    echo "  Open-Omniscience has been installed to: $INSTALL_DIR"
    echo ""
    
    # Ask if user wants to launch the program
    if [ "$INTERACTIVE" = true ]; then
        read -p "Do you want to launch Open-Omniscience now? (Y/n): " -n 1 -r
        echo ""
        if [[ $REPLY =~ ^[Yy]$ ]] || [[ -z $REPLY ]]; then
            echo ""
            log_info "Launching Open-Omniscience..."
            cd "$INSTALL_DIR"
            # Use full path to uvicorn from venv to ensure it works
            VENV_UVICORN="$INSTALL_DIR/venv/bin/uvicorn"
            if [ -f "$VENV_UVICORN" ]; then
                "$VENV_UVICORN" src.api.main:app --host 0.0.0.0 --port 8000 --reload &
            else
                # Fallback: try with python -m
                "$INSTALL_DIR/venv/bin/python" -m uvicorn src.api.main:app --host 0.0.0.0 --port 8000 --reload &
            fi
            
            # Check if it started successfully
            sleep 5
            # Try multiple pgrep patterns to be more reliable
            if pgrep -f "uvicorn" >/dev/null 2>&1 || pgrep -f "src.api.main:app" >/dev/null 2>&1 || pgrep -f "open-omniscience" >/dev/null 2>&1; then
                log_success "Open-Omniscience is running!"
                echo ""
                echo "  Access the application at: http://localhost:8000"
                echo ""
                
                # Ask if user wants to open in browser
                if command_exists xdg-open; then
                    read -p "Do you want to open it in your browser? (Y/n): " -n 1 -r
                    echo ""
                    if [[ $REPLY =~ ^[Yy]$ ]] || [[ -z $REPLY ]]; then
                        xdg-open http://localhost:8000
                    fi
                fi
            else
                # Check if the port is listening
                if command_exists curl; then
                    if curl -s -o /dev/null -w "%{http_code}" http://localhost:8000 2>/dev/null | grep -q "200\|301\|302"; then
                        log_success "Open-Omniscience is running!"
                        echo ""
                        echo "  Access the application at: http://localhost:8000"
                    else
                        log_warning "Open-Omniscience may not have started. Check with: pgrep -f uvicorn"
                        echo ""
                        echo "  Trying to check the process manually..."
                        ps aux | grep uvicorn | grep -v grep || true
                        echo ""
                        echo "  You can start it manually with:"
                        echo "    cd $INSTALL_DIR"
                        echo "    $INSTALL_DIR/venv/bin/python -m uvicorn src.api.main:app --host 0.0.0.0 --port 8000 --reload"
                    fi
                else
                    log_warning "Open-Omniscience may not have started. Check with: pgrep -f uvicorn"
                    echo ""
                    echo "  Trying to check the process manually..."
                    ps aux | grep uvicorn | grep -v grep || true
                    echo ""
                    echo "  You can start it manually with:"
                    echo "    cd $INSTALL_DIR"
                    echo "    $INSTALL_DIR/venv/bin/python -m uvicorn src.api.main:app --host 0.0.0.0 --port 8000 --reload"
                fi
            fi
        else
            echo ""
            log_info "To start Open-Omniscience manually:"
            echo "    cd $INSTALL_DIR"
            echo "    source venv/bin/activate"
            echo "    uvicorn src.api.main:app --host 0.0.0.0 --port 8000 --reload"
            echo ""
            echo "  Then access at: http://localhost:8000"
        fi
    else
        echo ""
        log_info "To start Open-Omniscience:"
        echo "    cd $INSTALL_DIR"
        echo "    source venv/bin/activate"
        echo "    uvicorn src.api.main:app --host 0.0.0.0 --port 8000 --reload"
        echo ""
        echo "  Then access at: http://localhost:8000"
    fi
    
    echo ""
    echo "  To install Ollama later for LLM support:"
    echo "    curl -fsSL https://ollama.com/install.sh | sh"
    echo "    ollama pull gemma4:e2b"
    echo "    # Then restart Open-Omniscience"
    echo ""
    echo "  For production deployment:"
    echo "    pip install gunicorn"
    echo "    gunicorn -k uvicorn.workers.UvicornWorker -w 4 -b 0.0.0.0:8000 src.api.main:app"
    echo ""
    echo "  Documentation: https://github.com/ideotion/Open-Omniscience"
    echo ""
    echo "  GUI Installer: Run installer/gui_installer.py for a graphical installation"
    echo ""
    echo "  Debug Tool: Run scripts/debug_install.sh to diagnose installation issues"
    echo ""
}

# Run main function
main "$@"
