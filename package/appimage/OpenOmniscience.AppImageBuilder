}

# Build AppImage
build_appimage() {
    echo -e "${GREEN}Building AppImage...${NC}"
    
    # Check if linuxdeploy is available
    if ! command -v linuxdeploy &> /dev/null; then
        echo -e "${RED}Error: linuxdeploy not found. Please install it first.${NC}"
        echo ""
        echo "To install linuxdeploy on Ubuntu/Debian:"
        echo "  wget https://github.com/linuxdeploy/linuxdeploy/releases/download/continuous/linuxdeploy-x86_64.AppImage"
        echo "  chmod +x linuxdeploy-x86_64.AppImage"
        echo "  sudo mv linuxdeploy-x86_64.AppImage /usr/local/bin/linuxdeploy"
        echo ""
        echo "Or visit: https://github.com/linuxdeploy/linuxdeploy"
        exit 1
    fi
    
    # Check if appimagetool is available
    if ! command -v appimagetool &> /dev/null; then
        echo -e "${RED}Error: appimagetool not found. Please install it first.${NC}"
        echo ""
        echo "To install appimagetool on Ubuntu/Debian:"
        echo "  wget https://github.com/AppImage/AppImageKit/releases/download/continuous/appimagetool-x86_64.AppImage"
        echo "  chmod +x appimagetool-x86_64.AppImage"
        echo "  sudo mv appimagetool-x86_64.AppImage /usr/local/bin/appimagetool"
        echo ""
        echo "Or visit: https://github.com/AppImage/AppImageKit"
        exit 1
    fi
    
    # Build the AppImage
    echo -e "${GREEN}Running linuxdeploy...${NC}"
    linuxdeploy-x86_64.AppImage \
        --appdir "$APPDIR" \
        --desktop-file "$APPDIR/open-omniscience.desktop" \
        --icon-filename "$APPDIR/usr/share/icons/hicolor/256x256/apps/open-omniscience.png" \
        --executable "$APPDIR/AppRun" \
        --output appimage
    
    # Move the AppImage to output directory
    if [ -f "OpenOmniscience-${APP_VERSION}-x86_64.AppImage" ]; then
        mv "OpenOmniscience-${APP_VERSION}-x86_64.AppImage" "$OUTPUT_DIR/$FINAL_APPIMAGE"
        chmod +x "$OUTPUT_DIR/$FINAL_APPIMAGE"
        echo -e "${GREEN}AppImage created: $OUTPUT_DIR/$FINAL_APPIMAGE${NC}"
    else
        echo -e "${RED}Error: AppImage was not created. Check for errors above.${NC}"
        exit 1
    fi
}

# Main execution
main() {
    echo "=========================================="
    echo "Open Omniscience AppImage Builder"
    echo "Version: $APP_VERSION"
    echo "=========================================="
    echo ""
    
    cleanup
    create_structure
    copy_files
    create_wrapper
    create_apprun
    create_desktop
    create_appstream
    build_appimage
    
    echo ""
    echo "=========================================="
    echo -e "${GREEN}AppImage build complete!${NC}"
    echo ""
    echo "Output: $OUTPUT_DIR/$FINAL_APPIMAGE"
    echo ""
    echo "To run the AppImage:"
    echo "  ./dist/OpenOmniscience-${APP_VERSION}-x86_64.AppImage"
    echo ""
    echo "To make it executable:"
    echo "  chmod +x dist/OpenOmniscience-${APP_VERSION}-x86_64.AppImage"
    echo "=========================================="
}

# Run main function
main "$@"
