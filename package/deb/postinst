#!/bin/bash
set -e

# Post-installation script for Open-Omniscience
# This script runs after the package is installed

INSTALL_DIR="/opt/open-omniscience"

# Make the install script executable
chmod +x "$INSTALL_DIR/install"

# Run the install script in non-interactive mode
echo "Running Open-Omniscience installer..."
cd "$INSTALL_DIR"
./install

# Create a symlink in /usr/local/bin for easy access
if [ ! -f "/usr/local/bin/open-omniscience" ]; then
    ln -s "$INSTALL_DIR/install" /usr/local/bin/open-omniscience
fi

echo "Open-Omniscience installation complete!"
echo "You can now run 'open-omniscience' from anywhere or cd to $INSTALL_DIR"
echo "To start the application: source venv/bin/activate && uvicorn api.main:app --host 0.0.0.0 --port 8000"

exit 0
