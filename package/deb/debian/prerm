#!/bin/bash
# Pre-removal script for Open Omniscience
# This script runs before the package is removed

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Configuration
DESKTOP_FILE="open-omniscience-user.desktop"
APP_DESKTOP_FILE="open-omniscience.desktop"

# Function to get user's desktop directory
get_desktop_dir() {
    if [ -n "$XDG_DESKTOP_DIR" ] && [ -d "$XDG_DESKTOP_DIR" ]; then
        echo "$XDG_DESKTOP_DIR"
        return 0
    fi
    
    if [ -d "$HOME/Desktop" ]; then
        echo "$HOME/Desktop"
        return 0
    fi
    
    echo "$HOME/Desktop"
}

# Function to get user's local applications directory
get_local_apps_dir() {
    if [ -n "$XDG_DATA_HOME" ]; then
        echo "$XDG_DATA_HOME/applications"
    else
        echo "$HOME/.local/share/applications"
    fi
}

# Function to get user's local icons directory
get_local_icons_dir() {
    if [ -n "$XDG_DATA_HOME" ]; then
        echo "$XDG_DATA_HOME/icons"
    else
        echo "$HOME/.local/share/icons"
    fi
}

# Function to remove desktop launcher
remove_desktop_launcher() {
    local desktop_dir
    local apps_dir
    local icons_dir
    
    desktop_dir=$(get_desktop_dir)
    apps_dir=$(get_local_apps_dir)
    icons_dir=$(get_local_icons_dir)
    
    echo -e "${YELLOW}Removing Open Omniscience desktop launcher...${NC}"
    
    # Remove from user's desktop
    if [ -f "$desktop_dir/$DESKTOP_FILE" ]; then
        rm -f "$desktop_dir/$DESKTOP_FILE"
        echo -e "${GREEN}Removed desktop launcher from: $desktop_dir/$DESKTOP_FILE${NC}"
    fi
    
    # Remove from user's applications
    if [ -f "$apps_dir/$DESKTOP_FILE" ]; then
        rm -f "$apps_dir/$DESKTOP_FILE"
        echo -e "${GREEN}Removed desktop launcher from: $apps_dir/$DESKTOP_FILE${NC}"
    fi
    
    # Remove from system applications
    if [ -f "/usr/share/applications/$APP_DESKTOP_FILE" ]; then
        rm -f "/usr/share/applications/$APP_DESKTOP_FILE"
        echo -e "${GREEN}Removed desktop launcher from: /usr/share/applications/$APP_DESKTOP_FILE${NC}"
    fi
    
    # Remove icon
    if [ -f "$icons_dir/open-omniscience.png" ]; then
        rm -f "$icons_dir/open-omniscience.png"
        echo -e "${GREEN}Removed icon from: $icons_dir/open-omniscience.png${NC}"
    fi
    
    echo -e "${GREEN}Desktop launcher removal complete!${NC}"
}

# Main execution
case "$1" in
    remove|upgrade|failed-upgrade)
        echo ""
        echo "=========================================="
        echo "Open Omniscience - Pre-Removal Cleanup"
        echo "=========================================="
        echo ""
        
        # Remove desktop launcher
        remove_desktop_launcher
        
        echo ""
        ;;
    *)
        # For other cases, do nothing
        ;;
esac

exit 0
