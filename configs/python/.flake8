[flake8]
max-line-length = 100
max-complexity = 10
exclude = 
    .git,
    __pycache__,
    .venv,
    venv,
    migrations,
    node_modules,
    dist,
    build,
    *.egg-info
ignore = 
    E203,  # Whitespace before ':' (conflicts with black)
    W503,  # Line break before binary operator (conflicts with black)
    E501,  # Line too long (handled by black)
    E302,  # Expected 2 blank lines (sometimes conflicts with black)
    E305,  # Expected 2 blank lines after class definition
    F401,  # Imported but unused (handled by isort/auto-import cleanup)
    F403,  # 'from module import *' used
    F405,  # Name may be undefined (false positives with TYPE_CHECKING)
    W605,  # Invalid escape sequence
    B008,  # Do not perform function calls in argument defaults
    B902,  # Invalid first argument for function (for classmethods)
    RST201, # 'Inline emphasis start-string without end-string'
    RST301, # 'Field list ends without a blank line; unexpected unindent'

per-file-ignores = 
    src/database/migrations/*: E302,E305
    tests/*: E302,E305,F401
    */tests/*: E302,E305,F401
    setup.py: F401

select = 
    E,F,W,C,B,B9,RST

count = true
show-source = true
statistics = true

# Type checking
doctest = false
