# Open-Omniscience Production Environment Configuration
# 
# This file contains example configuration for production deployment.
# Copy this file to .env.production and customize the values.
#
# IMPORTANT: Never commit the actual .env.production file to version control!
# Keep it secure and only share with authorized personnel.
#
# Author: Open-Omniscience Team
# License: Open Source (MIT)

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Database (Recommended for Production)
POSTGRES_DB=open_omniscience
POSTGRES_USER=omniscience
# POSTGRES_PASSWORD= (Set a strong password, 32+ characters)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Alternative: SQLite (for development/testing only)
# DATABASE_URL=sqlite:///./data/open_omniscience.db

# =============================================================================
# API CONFIGURATION
# =============================================================================

# Environment
ENVIRONMENT=production
DEBUG=false

# Secret Key for JWT, sessions, and security utilities
# Generate with: openssl rand -hex 32
# SECRET_KEY= (Generate a strong secret key, 64+ characters recommended)

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Rate limiting
RATE_LIMIT=100/minute

# API port (internal, Nginx handles external traffic)
API_PORT=8000

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# LLM CONFIGURATION (Optional)
# =============================================================================

# Ollama configuration
OLLAMA_BASE_URL=http://ollama:11434
AUTO_DOWNLOAD_MODELS=false

# Model settings
DEFAULT_MODEL=llama3
MAX_CONTEXT_LENGTH=4096
TEMPERATURE=0.7
TOP_P=0.9
TOP_K=50

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================

# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=15s

# Grafana
# GRAFANA_ADMIN_USER= (Set admin username)
# GRAFANA_ADMIN_PASSWORD= (Set admin password)
GRAFANA_PORT=3000

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json, text
LOG_FORMAT=json

# Log file locations
API_LOG_FILE=/var/log/open-omniscience/api.log
ERROR_LOG_FILE=/var/log/open-omniscience/error.log
ACCESS_LOG_FILE=/var/log/open-omniscience/access.log

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT Authentication (if implemented)
# JWT_SECRET_KEY= (Generate with: openssl rand -hex 32)
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# Session settings
# SESSION_SECRET= (Generate with: openssl rand -hex 32)
SESSION_TIMEOUT=3600

# CSRF protection
# CSRF_SECRET= (Generate with: openssl rand -hex 32)
CSRF_TIMEOUT=3600

# =============================================================================
# EMAIL CONFIGURATION (Optional - for notifications)
# =============================================================================

SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=notifications@yourdomain.com
# SMTP_PASSWORD= (Set your email password)
SMTP_USE_TLS=true

EMAIL_FROM=notifications@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# =============================================================================
# SSL/TLS CONFIGURATION
# =============================================================================

# SSL certificate paths (mounted in Nginx container)
SSL_CERTIFICATE=/etc/nginx/ssl/fullchain.pem
SSL_CERTIFICATE_KEY=/etc/nginx/ssl/privkey.pem
SSL_CERTIFICATE_CHAIN=/etc/nginx/ssl/chain.pem

# Let's Encrypt configuration
LE_EMAIL=admin@yourdomain.com
LE_DOMAIN=yourdomain.com

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================

# Backup settings
BACKUP_DIR=/backups
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM

# Database backup
DB_BACKUP_ENABLED=true
DB_BACKUP_COMPRESSION=true

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================

# Worker settings
WORKER_COUNT=4
WORKER_TIMEOUT=30
WORKER_MAX_REQUESTS=1000
WORKER_MAX_REQUESTS_JITTER=50

# Connection pooling
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Cache settings
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable features
ENABLE_ANALYTICS=true
ENABLE_MONITORING=true
ENABLE_RATE_LIMITING=true
ENABLE_CORS=true
ENABLE_COMPRESSION=true
ENABLE_HTTPS_REDIRECT=true

# =============================================================================
# CUSTOM CONFIGURATION
# =============================================================================

# Add any custom environment variables needed for your deployment
# CUSTOM_VAR=value

# =============================================================================
# NOTES
# =============================================================================

# 1. Always use strong, unique passwords for all services
# 2. Rotate secrets regularly (every 90 days recommended)
# 3. Store secrets in a secure vault or secret manager
# 4. Never hardcode secrets in source code
# 5. Use environment-specific configuration files
# 6. Test configuration changes in staging before production
# 7. Monitor logs for security issues
# 8. Keep all software up to date

# For production, consider using a secrets manager like:
# - HashiCorp Vault
# - AWS Secrets Manager
# - Azure Key Vault
# - Google Cloud Secret Manager
