    AN[("article_analyses table<br/>kind/result/model/prompt_version")]
    O["Ollama daemon<br/>OO_OLLAMA_URL (default http://127.0.0.1:11434)<br/>external native binary, HTTP only"]

    S -->|"load article"| DB
    T -->|"load article"| DB
    H & M & G & S & T --> C
