flowchart LR
    subgraph API ["FastAPI (src/api/llm.py)"]
        H["GET /api/llm/health"]
        M["GET /api/llm/models"]
        G["POST /api/llm/generate"]
        S["POST /api/llm/articles/{id}/summarize"]
        T["POST /api/llm/articles/{id}/translate"]
    end
